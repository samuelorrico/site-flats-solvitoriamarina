# ── Site (já em uso) ───────────────────────────────────────────────
# Domínio final → liga indexação + URLs absolutas (canonical/OG/sitemap).
NEXT_PUBLIC_SITE_URL=https://vitoriamarinaflats.com.br

# ── Google Ads (conversão do clique no WhatsApp) ───────────────────
# INTERRUPTOR: sem NEXT_PUBLIC_GADS_ID o site NÃO carrega nada do Google,
# não cria cookie de publicidade e o banner de consentimento nem aparece.
# Ao setar, o banner aparece e o tag só carrega se o visitante ACEITAR.
NEXT_PUBLIC_GADS_ID=                    # ex.: AW-123456789
NEXT_PUBLIC_GADS_CONVERSION_LABEL=      # rótulo da conversão (Google Ads → Conversões)

# ── Bot WhatsApp (M3 / feature 05) — preencher na Vercel e no .env.local ──
# Webhook (Meta)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OWNER_NUMBER=        # wa_id da proprietária (escalonamento), ex.: 5571991159858
META_APP_SECRET=             # App Secret da Meta → valida a assinatura do webhook (recomendado)

# IA — 'claude' (recomendado) ou 'groq'
AI_PROVIDER=claude
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Memória de conversa (opcional; sem isso usa in-memory) — Upstash Redis REST
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
